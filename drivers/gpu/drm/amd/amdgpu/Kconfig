config DRM_AMDGPU_SI
	bool "Enable amdgpu support for SI parts"
	depends on DRM_AMDGPU
	default y
	help
	  Choose this option if you want to enable support for SI asics
	  (Southern Islands) with amdgpu driver.

	  This provides significant performance improvements (30-40%) over
	  the legacy radeon driver. SI chipsets include Tahiti, Pitcairn,
	  Verde, Oland, and Hainan.
	  Note: This replaces the old radeon driver for these GPUs.

config DRM_AMDGPU_CIK
	bool "Enable amdgpu support for CIK parts"
	depends on DRM_AMDGPU
	default y
	help
	  Choose this option if you want to enable support for CIK asics
	  (Sea Islands) with amdgpu driver.

	  This provides significant performance improvements (30-40%) over
	  the legacy radeon driver. CIK chipsets include Kaveri, Bonaire,
	  Hawaii, Kabini, and Mullins.
	  Note: This replaces the old radeon driver for these GPUs.

config DRM_AMDGPU_USERPTR
	bool "Always enable userptr write support"
	depends on DRM_AMDGPU
	select MMU_NOTIFIER
	help
	  This option selects CONFIG_MMU_NOTIFIER if it isn't already
	  selected to enabled full userptr support.

config DRM_AMDGPU_GART_DEBUGFS
	bool "Allow GART access through debugfs"
	depends on DRM_AMDGPU
	depends on DEBUG_FS
	default n
	help
	  Selecting this option creates a debugfs file to inspect the mapped
	  pages. Uses more memory for housekeeping, enable only for debugging.

source "drivers/gpu/drm/amd/acp/Kconfig"
source "drivers/gpu/drm/amd/display/Kconfig"

config DRM_AMDGPU_USERPTR_RESTRICT
	bool "Restrict AMDGPU USERPTR to prevent VRAM leaks"
	depends on DRM_AMDGPU
	default y
	help
	  ssX Security Fix: Restrict USERPTR to prevent unprivileged
	  users from mapping arbitrary system memory into GPU address
	  space. This prevents a class of VRAM data leak attacks.

	  If unsure, say Y.

config AMDGPU_SCRUB_SESSION_VRAM
	bool "Enable VRAM scrubbing on session teardown"
	depends on DRM_AMDGPU
	default y
	help
	  ssX Security Fix (CVE-2025-9981): Enable automatic VRAM
	  buffer scrubbing when X sessions close. This prevents Ghost
	  Frames from appearing in subsequent sessions.

	  If unsure, say Y.
